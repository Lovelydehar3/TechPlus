# ============================================================
#  TechPlus Server — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# Server
PORT=5000
# IMPORTANT: Set NODE_ENV=production on Render (via Render dashboard env vars).
# Do NOT set NODE_ENV=development in your production .env file.
NODE_ENV=production

# MongoDB Atlas (use SRV format for Render)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/techplus?retryWrites=true&w=majority&appName=TechPlus
MONGO_URI_FALLBACK=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/techplus?retryWrites=true&w=majority&appName=TechPlus

# Comma-separated emails that always receive admin role (synced on login)
ADMIN_EMAILS=your_admin@gmail.com,karansharma202005@gmail.com

# JWT (use long random strings — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_another_64_char_random_string

# Gmail SMTP (use App Password from myaccount.google.com/apppasswords)
EMAIL=your_gmail@gmail.com
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# Render blocks outbound SMTP on free tier — relay through Vercel (client/api/send-email.js)
EMAIL_FORCE_RELAY=true
EMAIL_RELAY_URL=https://your-vercel-app.vercel.app/api/send-email
EMAIL_RELAY_SECRET=replace_with_long_random_secret
EMAIL_TIMEOUT_MS=12000

# Frontend URL — set to your Vercel deployment URL in production
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Allow Vercel preview/live domains in production CORS checks
ALLOW_VERCEL_PREVIEW_ORIGINS=true

# News APIs (optional but recommended)
NEWSAPI_KEY=your_newsapi_org_key
GNEWS_API_KEY=your_gnews_io_key
NEWSAPI_URL=https://newsapi.org/v2/top-headlines
GNEWS_API_URL=https://gnews.io/api/v4/search

# Hackathon API
DEVFOLIO_HACKATHON_FEEDS=https://devfolio.co/hackathons,https://devfolio.co/explore
HACKATHON_SYNC_ON_BOOT=false

# Cookie settings are now handled automatically:
# Production: sameSite=none, secure=true (for Vercel→Render cross-origin)
# Development: sameSite=lax, secure=false (for localhost)
# COOKIE_SAME_SITE is no longer needed — it is forced by NODE_ENV.

# Static file serving — keep false when deploying frontend to Vercel separately
SERVE_STATIC=false

# Enable data seeding on startup (set to true on production)
ENABLE_STARTUP_WARMUPS=false

# FIX #3: Emergency bypass for email verification.
# When true, registration skips OTP email and marks isVerified=true immediately.
# Use ONLY for development or when email service is down in production.
DISABLE_EMAIL_VERIFICATION=false
