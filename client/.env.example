# ============================================================
#  TechPlus Client — Environment Variables
#  Copy to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# Backend API URL
# Development: http://localhost:5000
# Production: set this to your Render backend URL
VITE_API_URL=http://localhost:5000
VITE_API_BASE_URL=http://localhost:5000

# Optional production fallback for the same Render backend.
VITE_RENDER_API_URL=https://your-render-backend.onrender.com

# Keep false for Vercel + Render split deployment.
# Set true only if frontend and backend are served from same domain with /api proxy.
VITE_USE_SAME_ORIGIN_API=false

# Vercel serverless email relay (client/api/send-email.js).
# These are server-side Vercel env vars, not browser VITE_ vars.
EMAIL=your_gmail@gmail.com
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_RELAY_SECRET=replace_with_same_secret_as_render_optional
